{
  "$schema": "https://opencode.ai/config.json",

  "instructions": [
    "START-HERE.md",
    "docs/skill-index.md"
  ],

  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow",
      ".npmrc": "deny",
      ".pypirc": "deny",
      ".netrc": "deny",
      ".ssh/*": "deny",
      "**/.ssh/*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "*service-account*.json": "deny",
      "*credentials*.json": "deny",
      "*secrets*.json": "deny"
    },
    "glob": "allow",
    "grep": "ask",
    "lsp": "allow",
    "todowrite": "allow",
    "external_directory": "ask",
    "task": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "question": "allow",
    "doom_loop": "ask",
    "edit": "ask",
    "bash": "ask",
    "skill": {
      "*": "ask",
      "brainstorming": "allow",
      "brutalist-skill": "allow",
      "dispatching-parallel-agents": "allow",
      "executing-plans": "allow",
      "finishing-a-development-branch": "allow",
      "frontend-skill": "allow",
      "gpt-tasteskill": "allow",
      "minimalist-skill": "allow",
      "react-best-practices": "allow",
      "receiving-code-review": "allow",
      "redesign-skill": "allow",
      "requesting-code-review": "allow",
      "shadcn": "allow",
      "soft-skill": "allow",
      "stitch-skill": "allow",
      "subagent-driven-development": "allow",
      "systematic-debugging": "allow",
      "taste-skill": "allow",
      "test-driven-development": "allow",
      "using-git-worktrees": "allow",
      "using-superpowers": "allow",
      "verification-before-completion": "allow",
      "writing-plans": "allow",
      "writing-skills": "allow"
    }
  }
}
